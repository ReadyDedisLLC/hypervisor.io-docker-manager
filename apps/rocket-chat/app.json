{
  "name": "Rocket.Chat",
  "slug": "rocket-chat",
  "description": "Open-source team communication platform with channels, direct messaging, video calls, and extensive integrations.",
  "icon": "icon.png",
  "category": "communication",
  "version": "latest",
  "website": "https://rocket.chat",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 1024,
  "min_storage_gb": 10,
  "env": [
    {
      "key": "ROOT_URL",
      "label": "Site URL",
      "default": "http://localhost:3000",
      "required": true,
      "type": "text",
      "description": "Public URL of your Rocket.Chat instance"
    }
  ],
  "ports": [
    {
      "container_port": 3000,
      "default_host_port": 3000,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
