{
  "name": "Dify",
  "slug": "dify",
  "description": "LLM app development platform for building AI-powered chatbots, agents, and workflow automations.",
  "icon": "icon.png",
  "category": "ai",
  "version": "latest",
  "website": "https://dify.ai",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 4096,
  "min_storage_gb": 20,
  "env": [
    {
      "key": "SECRET_KEY",
      "label": "Secret Key",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Secret key for session and data encryption"
    },
    {
      "key": "DB_USERNAME",
      "label": "Database Username",
      "default": "postgres",
      "required": true,
      "type": "text",
      "description": "Username for the PostgreSQL database"
    },
    {
      "key": "DB_PASSWORD",
      "label": "Database Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the PostgreSQL database"
    },
    {
      "key": "REDIS_PASSWORD",
      "label": "Redis Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the Redis instance"
    }
  ],
  "ports": [
    {
      "container_port": 3000,
      "default_host_port": 3000,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
