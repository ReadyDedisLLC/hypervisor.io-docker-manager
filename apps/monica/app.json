{
  "name": "Monica",
  "slug": "monica",
  "description": "Personal CRM to organize interactions with friends, family, and contacts.",
  "icon": "icon.png",
  "category": "productivity",
  "version": "latest",
  "website": "https://monicahq.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "APP_KEY",
      "label": "App Key",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Laravel app key for encryption"
    },
    {
      "key": "DB_PASSWORD",
      "label": "Database Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the MySQL database"
    }
  ],
  "ports": [
    {
      "container_port": 80,
      "default_host_port": 8085,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
