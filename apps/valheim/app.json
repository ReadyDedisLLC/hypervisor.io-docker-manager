{
  "name": "Valheim Server",
  "slug": "valheim",
  "description": "Dedicated Valheim multiplayer server with automatic updates, world backups, and BepInEx mod support.",
  "icon": "icon.png",
  "category": "gaming",
  "version": "latest",
  "website": "https://github.com/lloesche/valheim-server-docker",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 4096,
  "min_storage_gb": 10,
  "env": [
    {
      "key": "SERVER_NAME",
      "label": "Server Name",
      "default": "My Valheim Server",
      "required": true,
      "type": "text",
      "description": "Name displayed in the server browser"
    },
    {
      "key": "WORLD_NAME",
      "label": "World Name",
      "default": "Dedicated",
      "required": true,
      "type": "text",
      "description": "Name of the Valheim world"
    },
    {
      "key": "SERVER_PASS",
      "label": "Server Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password to join the server (minimum 5 characters)"
    }
  ],
  "ports": [
    {
      "container_port": 2456,
      "default_host_port": 2456,
      "protocol": "udp",
      "label": "Game Port",
      "configurable": true
    },
    {
      "container_port": 2457,
      "default_host_port": 2457,
      "protocol": "udp",
      "label": "Query Port",
      "configurable": true
    }
  ]
}
