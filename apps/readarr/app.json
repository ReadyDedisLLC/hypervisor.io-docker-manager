{
  "name": "Readarr",
  "slug": "readarr",
  "description": "Book and ebook collection manager that monitors RSS feeds and integrates with download clients to manage your library.",
  "icon": "icon.png",
  "category": "media",
  "version": "develop",
  "website": "https://readarr.com",
  "supported_distros": ["ubuntu-22.04","ubuntu-24.04","debian-12","rocky-9","almalinux-9"],
  "min_ram_mb": 512,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "PUID",
      "label": "User ID",
      "default": "1000",
      "required": false,
      "type": "number",
      "description": "UID for file permissions"
    },
    {
      "key": "PGID",
      "label": "Group ID",
      "default": "1000",
      "required": false,
      "type": "number",
      "description": "GID for file permissions"
    }
  ],
  "ports": [
    {
      "container_port": 8787,
      "default_host_port": 8787,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
