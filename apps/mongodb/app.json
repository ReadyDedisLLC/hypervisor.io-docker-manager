{
  "name": "MongoDB",
  "slug": "mongodb",
  "description": "General-purpose NoSQL document database designed for modern application development and cloud deployment.",
  "icon": "icon.png",
  "category": "databases",
  "version": "7",
  "website": "https://www.mongodb.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "MONGO_INITDB_ROOT_USERNAME",
      "label": "Root Username",
      "default": "admin",
      "required": true,
      "type": "text",
      "description": "MongoDB root admin username"
    },
    {
      "key": "MONGO_INITDB_ROOT_PASSWORD",
      "label": "Root Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "MongoDB root admin password"
    }
  ],
  "ports": [
    {
      "container_port": 27017,
      "default_host_port": 27017,
      "protocol": "tcp",
      "label": "MongoDB",
      "configurable": true
    }
  ]
}
