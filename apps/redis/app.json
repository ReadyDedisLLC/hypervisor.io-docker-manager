{
  "name": "Redis",
  "slug": "redis",
  "description": "In-memory data store used as a database, cache, message broker, and streaming engine.",
  "icon": "icon.png",
  "category": "databases",
  "version": "7",
  "website": "https://redis.io",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 128,
  "min_storage_gb": 2,
  "env": [
    {
      "key": "REDIS_PASSWORD",
      "label": "Redis Password",
      "default": "",
      "required": false,
      "type": "password",
      "generate": true,
      "description": "Optional password for Redis authentication"
    }
  ],
  "ports": [
    {
      "container_port": 6379,
      "default_host_port": 6379,
      "protocol": "tcp",
      "label": "Redis",
      "configurable": true
    }
  ]
}
