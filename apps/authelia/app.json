{
  "name": "Authelia",
  "slug": "authelia",
  "description": "Authentication and authorization server providing SSO, 2FA, and access control for your applications.",
  "icon": "icon.png",
  "category": "security",
  "version": "latest",
  "website": "https://www.authelia.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 256,
  "min_storage_gb": 2,
  "env": [
    {
      "key": "AUTHELIA_JWT_SECRET",
      "label": "JWT Secret",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Secret key used for signing JWTs"
    },
    {
      "key": "AUTHELIA_SESSION_SECRET",
      "label": "Session Secret",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Secret key used for session encryption"
    },
    {
      "key": "AUTHELIA_STORAGE_ENCRYPTION_KEY",
      "label": "Storage Encryption Key",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Encryption key for the storage backend"
    }
  ],
  "ports": [
    {
      "container_port": 9091,
      "default_host_port": 9091,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
