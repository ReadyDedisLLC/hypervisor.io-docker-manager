{
  "name": "Zulip",
  "slug": "zulip",
  "description": "Threaded team chat platform designed for productive conversations with topic-based threading.",
  "icon": "icon.png",
  "category": "communication",
  "version": "latest",
  "website": "https://zulip.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 4096,
  "min_storage_gb": 20,
  "env": [
    {
      "key": "SETTING_EXTERNAL_HOST",
      "label": "External Host",
      "default": "localhost",
      "required": true,
      "type": "text",
      "description": "The external hostname for your Zulip instance"
    },
    {
      "key": "SETTING_ZULIP_ADMINISTRATOR",
      "label": "Admin Email",
      "default": "admin@example.com",
      "required": true,
      "type": "text",
      "description": "Email address of the Zulip administrator"
    },
    {
      "key": "SECRETS_secret_key",
      "label": "Secret Key",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Secret key for Zulip session management"
    },
    {
      "key": "SECRETS_postgres_password",
      "label": "PostgreSQL Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the Zulip PostgreSQL database"
    }
  ],
  "ports": [
    {
      "container_port": 80,
      "default_host_port": 8080,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
