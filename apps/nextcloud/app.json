{
  "name": "Nextcloud",
  "slug": "nextcloud",
  "description": "Self-hosted productivity and file storage platform — a complete alternative to Google Drive, Calendar, and Contacts.",
  "icon": "icon.png",
  "category": "file-storage",
  "version": "latest",
  "website": "https://nextcloud.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 1024,
  "min_storage_gb": 20,
  "env": [
    {
      "key": "MYSQL_ROOT_PASSWORD",
      "label": "MySQL Root Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Root password for the MariaDB database"
    },
    {
      "key": "MYSQL_PASSWORD",
      "label": "Database Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the Nextcloud database user"
    },
    {
      "key": "MYSQL_DATABASE",
      "label": "Database Name",
      "default": "nextcloud",
      "required": true,
      "type": "text",
      "description": "Name of the Nextcloud database"
    },
    {
      "key": "MYSQL_USER",
      "label": "Database User",
      "default": "nextcloud",
      "required": true,
      "type": "text",
      "description": "Database username for Nextcloud"
    }
  ],
  "ports": [
    {
      "container_port": 80,
      "default_host_port": 8080,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
