{
  "name": "MariaDB",
  "slug": "mariadb",
  "description": "Community-developed fork of MySQL with improved performance, new storage engines, and full MySQL compatibility.",
  "icon": "icon.png",
  "category": "databases",
  "version": "11",
  "website": "https://mariadb.org",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 256,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "MYSQL_ROOT_PASSWORD",
      "label": "Root Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "MariaDB root user password"
    },
    {
      "key": "MYSQL_DATABASE",
      "label": "Default Database",
      "default": "mydb",
      "required": false,
      "type": "text",
      "description": "Name of the default database to create"
    },
    {
      "key": "MYSQL_USER",
      "label": "Database User",
      "default": "",
      "required": false,
      "type": "text",
      "description": "Additional non-root user to create"
    },
    {
      "key": "MYSQL_PASSWORD",
      "label": "User Password",
      "default": "",
      "required": false,
      "type": "password",
      "generate": true,
      "description": "Password for the additional user"
    }
  ],
  "ports": [
    {
      "container_port": 3306,
      "default_host_port": 3306,
      "protocol": "tcp",
      "label": "MariaDB",
      "configurable": true
    }
  ]
}
