{
  "name": "Activepieces",
  "slug": "activepieces",
  "description": "No-code business automation platform for connecting apps and automating workflows with a visual builder.",
  "icon": "icon.png",
  "category": "automation",
  "version": "latest",
  "website": "https://activepieces.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 1024,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "AP_ENCRYPTION_KEY",
      "label": "Encryption Key",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Encryption key for securing sensitive data"
    },
    {
      "key": "AP_JWT_SECRET",
      "label": "JWT Secret",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Secret key for signing JWT tokens"
    },
    {
      "key": "AP_POSTGRES_PASSWORD",
      "label": "Database Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the PostgreSQL database"
    }
  ],
  "ports": [
    {
      "container_port": 80,
      "default_host_port": 8098,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
