{
  "name": "Text Generation WebUI",
  "slug": "text-generation-webui",
  "description": "Oobabooga web interface for running large language models with support for multiple backends and model formats.",
  "icon": "icon.png",
  "category": "ai",
  "version": "latest",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 8192,
  "min_storage_gb": 30,
  "env": [],
  "ports": [
    {
      "container_port": 7860,
      "default_host_port": 7860,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    },
    {
      "container_port": 5000,
      "default_host_port": 5000,
      "protocol": "tcp",
      "label": "API",
      "configurable": true
    }
  ]
}
