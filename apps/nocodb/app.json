  "min_storage_gb": 5,
  "env": [
    {"key":"NC_AUTH_JWT_SECRET","label":"JWT Secret","default":"","required":true,"type":"password","generate":true,"description":"Secret for JWT authentication tokens"}
  ],
  "ports": [{"container_port":8080,"default_host_port":8080,"protocol":"tcp","label":"Web UI","configurable":true}]
}
