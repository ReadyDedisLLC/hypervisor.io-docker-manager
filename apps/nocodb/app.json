{
  "name": "NocoDB",
  "slug": "nocodb",
  "description": "Open-source Airtable alternative that turns any SQL database into a smart spreadsheet with API access.",
  "icon": "icon.png",
  "category": "development",
  "version": "latest",
  "website": "https://nocodb.com",
  "supported_distros": ["ubuntu-22.04","ubuntu-24.04","debian-11","debian-12","rocky-9","almalinux-9","centos-stream-9"],
