{
  "name": "Standard Notes",
  "slug": "standardnotes",
  "description": "End-to-end encrypted notes app with a focus on privacy and longevity.",
  "icon": "icon.png",
  "category": "productivity",
  "version": "latest",
  "website": "https://standardnotes.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "DB_PASSWORD",
      "label": "Database Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the MySQL database"
    },
    {
      "key": "SECRET_KEY_BASE",
      "label": "Secret Key Base",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Secret key for application security"
    },
    {
      "key": "ENCRYPTION_SERVER_KEY",
      "label": "Encryption Server Key",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Key used for server-side encryption"
    }
  ],
  "ports": [
    {
      "container_port": 3000,
      "default_host_port": 3002,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
