{
  "name": "SonarQube",
  "slug": "sonarqube",
  "description": "Self-hosted code quality and security analysis platform for continuous inspection of code.",
  "icon": "icon.png",
  "category": "development",
  "version": "community",
  "website": "https://sonarqube.org",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 4096,
  "min_storage_gb": 20,
  "env": [
    {
      "key": "SONAR_JDBC_PASSWORD",
      "label": "Database Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the PostgreSQL database"
    }
  ],
  "ports": [
    {
      "container_port": 9000,
      "default_host_port": 9000,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
