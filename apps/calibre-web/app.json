{
  "name": "Calibre-Web",
  "slug": "calibre-web",
  "description": "Web-based ebook library and reader providing a clean interface for browsing, reading, and managing your book collection.",
  "icon": "icon.png",
  "category": "media",
  "version": "latest",
  "website": "https://github.com/janeczku/calibre-web",
  "supported_distros": ["ubuntu-22.04","ubuntu-24.04","debian-12","rocky-9","almalinux-9"],
  "min_ram_mb": 512,
  "min_storage_gb": 10,
  "env": [
    {
      "key": "PUID",
      "label": "User ID",
      "default": "1000",
      "required": false,
      "type": "number",
      "description": "UID for file permissions"
    },
    {
      "key": "PGID",
      "label": "Group ID",
      "default": "1000",
      "required": false,
      "type": "number",
      "description": "GID for file permissions"
    }
  ],
  "ports": [
    {
      "container_port": 8083,
      "default_host_port": 8083,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
