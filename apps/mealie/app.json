{
  "name": "Mealie",
  "slug": "mealie",
  "description": "Self-hosted recipe manager and meal planner with automatic recipe import from any URL and a shopping list.",
  "icon": "icon.png",
  "category": "productivity",
  "version": "latest",
  "website": "https://mealie.io",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 2,
  "env": [
    {
      "key": "DEFAULT_EMAIL",
      "label": "Admin Email",
      "default": "admin@example.com",
      "required": true,
      "type": "text",
      "description": "Default admin email for initial login"
    }
  ],
  "ports": [
    {
      "container_port": 9000,
      "default_host_port": 9925,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
