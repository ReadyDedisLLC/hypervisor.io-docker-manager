{
  "name": "AdGuard Home",
  "slug": "adguard-home",
  "description": "Network-wide DNS ad blocker with built-in DHCP, encrypted DNS support, and a modern web interface.",
  "icon": "icon.png",
  "category": "networking",
  "version": "latest",
  "website": "https://adguard.com/adguard-home.html",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 256,
  "min_storage_gb": 2,
  "env": [],
  "ports": [
    {
      "container_port": 3000,
      "default_host_port": 3000,
      "protocol": "tcp",
      "label": "Setup UI (initial)",
      "configurable": true
    },
    {
      "container_port": 80,
      "default_host_port": 8080,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    },
    {
      "container_port": 53,
      "default_host_port": 53,
      "protocol": "tcp",
      "label": "DNS (TCP)",
      "configurable": false
    },
    {
      "container_port": 53,
      "default_host_port": 53,
      "protocol": "udp",
      "label": "DNS (UDP)",
      "configurable": false
    }
  ]
}
