{
  "name": "Gitea",
  "slug": "gitea",
  "description": "Lightweight self-hosted Git service providing repository hosting, code review, and CI/CD pipelines.",
  "icon": "icon.png",
  "category": "development",
  "version": "latest",
  "website": "https://gitea.io",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 10,
  "env": [],
  "ports": [
    {
      "container_port": 3000,
      "default_host_port": 3000,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    },
    {
      "container_port": 22,
      "default_host_port": 2222,
      "protocol": "tcp",
      "label": "SSH",
      "configurable": true
    }
  ]
}
