{
  "name": "Grafana",
  "slug": "grafana",
  "description": "Open-source analytics and interactive visualization platform for monitoring metrics, logs, and traces.",
  "icon": "icon.png",
  "category": "monitoring",
  "version": "latest",
  "website": "https://grafana.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "GF_SECURITY_ADMIN_USER",
      "label": "Admin Username",
      "default": "admin",
      "required": true,
      "type": "text",
      "description": "Grafana admin username"
    },
    {
      "key": "GF_SECURITY_ADMIN_PASSWORD",
      "label": "Admin Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Grafana admin password"
    }
  ],
  "ports": [
    {
      "container_port": 3000,
      "default_host_port": 3000,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
