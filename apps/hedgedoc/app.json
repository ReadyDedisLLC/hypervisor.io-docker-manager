{
  "name": "HedgeDoc",
  "slug": "hedgedoc",
  "description": "Collaborative markdown editor for real-time team documentation and note-taking.",
  "icon": "icon.png",
  "category": "productivity",
  "version": "latest",
  "website": "https://hedgedoc.org",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "CMD_DB_PASSWORD",
      "label": "Database Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the HedgeDoc PostgreSQL database"
    },
    {
      "key": "CMD_SESSION_SECRET",
      "label": "Session Secret",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Secret key for session encryption"
    },
    {
      "key": "CMD_DOMAIN",
      "label": "Domain",
      "default": "localhost",
      "required": false,
      "type": "text",
      "description": "The domain name for your HedgeDoc instance"
    }
  ],
  "ports": [
    {
      "container_port": 3000,
      "default_host_port": 3000,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
