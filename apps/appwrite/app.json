{
  "name": "Appwrite",
  "slug": "appwrite",
  "description": "Open-source backend server for web and mobile apps with auth, database, storage, functions, and messaging.",
  "icon": "icon.png",
  "category": "development",
  "version": "latest",
  "website": "https://appwrite.io",
  "supported_distros": ["ubuntu-22.04","ubuntu-24.04","debian-12","rocky-9","almalinux-9"],
  "min_ram_mb": 2048,
  "min_storage_gb": 10,
  "env": [
    {"key":"_APP_OPENSSL_KEY_V1","label":"Encryption Key","default":"","required":true,"type":"password","generate":true,"description":"Secret key for encrypting data at rest"}
  ],
  "ports": [
    {"container_port":80,"default_host_port":8080,"protocol":"tcp","label":"Web UI","configurable":true},
    {"container_port":443,"default_host_port":8443,"protocol":"tcp","label":"HTTPS","configurable":true}
  ]
}
