  "min_ram_mb": 512,
  "min_storage_gb": 10,
  "env": [],
  "ports": [
    {
      "container_port": 3100,
      "default_host_port": 3100,
      "protocol": "tcp",
      "label": "API",
      "configurable": true
    }
