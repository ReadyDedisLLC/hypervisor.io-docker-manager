  "icon": "icon.png",
  "category": "monitoring",
  "version": "latest",
  "website": "https://grafana.com/oss/loki/",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
