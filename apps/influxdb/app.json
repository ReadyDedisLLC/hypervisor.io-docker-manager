{
  "name": "InfluxDB",
  "slug": "influxdb",
  "description": "Open-source time series database designed for high-performance storage and retrieval of time-stamped data.",
  "icon": "icon.png",
  "category": "databases",
  "version": "2",
  "website": "https://influxdata.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 10,
  "env": [
    {
      "key": "DOCKER_INFLUXDB_INIT_USERNAME",
      "label": "Admin Username",
      "default": "admin",
      "required": true,
      "type": "text",
      "description": "Username for the initial admin account"
    },
    {
      "key": "DOCKER_INFLUXDB_INIT_PASSWORD",
      "label": "Admin Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the initial admin account"
    },
    {
      "key": "DOCKER_INFLUXDB_INIT_ORG",
      "label": "Organization",
      "default": "myorg",
      "required": true,
      "type": "text",
      "description": "Name of the initial organization"
    },
    {
      "key": "DOCKER_INFLUXDB_INIT_BUCKET",
      "label": "Default Bucket",
      "default": "default",
      "required": true,
      "type": "text",
      "description": "Name of the initial bucket"
    }
  ],
  "ports": [
    {
      "container_port": 8086,
      "default_host_port": 8086,
      "protocol": "tcp",
      "label": "Web UI / API",
      "configurable": true
    }
  ]
}
