{
  "name": "Pi-hole",
  "slug": "pi-hole",
  "description": "Network-wide ad blocker and DNS sinkhole that protects all devices on your network from ads and trackers.",
  "icon": "icon.png",
  "category": "networking",
  "version": "latest",
  "website": "https://pi-hole.net",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 256,
  "min_storage_gb": 2,
  "env": [
    {
      "key": "WEBPASSWORD",
      "label": "Admin Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the Pi-hole admin dashboard"
    },
    {
      "key": "TZ",
      "label": "Timezone",
      "default": "America/New_York",
      "required": true,
      "type": "text",
      "description": "Timezone (e.g. America/New_York, Europe/London)"
    }
  ],
  "ports": [
    {
      "container_port": 80,
      "default_host_port": 8080,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    },
    {
      "container_port": 53,
      "default_host_port": 53,
      "protocol": "tcp",
      "label": "DNS (TCP)",
      "configurable": false
    },
    {
      "container_port": 53,
      "default_host_port": 53,
      "protocol": "udp",
      "label": "DNS (UDP)",
      "configurable": false
    }
  ]
}
