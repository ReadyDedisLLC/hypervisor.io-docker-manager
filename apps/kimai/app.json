{
  "name": "Kimai",
  "slug": "kimai",
  "description": "Self-hosted time tracking application for teams and freelancers with project management and invoicing features.",
  "icon": "icon.png",
  "category": "productivity",
  "version": "latest",
  "website": "https://kimai.org",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "ADMIN_EMAIL",
      "label": "Admin Email",
      "default": "admin@example.com",
      "required": true,
      "type": "text",
      "description": "Email address for the admin account"
    },
    {
      "key": "ADMIN_PASSWORD",
      "label": "Admin Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the admin account"
    },
    {
      "key": "DATABASE_PASSWORD",
      "label": "Database Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "Password for the MySQL database"
    }
  ],
  "ports": [
    {
      "container_port": 8001,
      "default_host_port": 8001,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
