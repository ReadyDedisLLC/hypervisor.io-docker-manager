{
  "name": "Stirling-PDF",
  "slug": "stirling-pdf",
  "description": "Powerful locally hosted PDF manipulation tool with splitting, merging, converting, OCR, and 30+ other operations.",
  "icon": "icon.png",
  "category": "productivity",
  "version": "latest",
  "website": "https://github.com/Stirling-Tools/Stirling-PDF",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 2,
  "env": [
    {
      "key": "DOCKER_ENABLE_SECURITY",
      "label": "Enable Security",
      "default": "false",
      "required": false,
      "type": "select",
      "options": [
        { "label": "Disabled", "value": "false" },
        { "label": "Enabled", "value": "true" }
      ],
      "description": "Enable login authentication for the web interface"
    }
  ],
  "ports": [
    {
      "container_port": 8080,
      "default_host_port": 8080,
      "protocol": "tcp",
      "label": "Web UI",
      "configurable": true
    }
  ]
}
