{
  "name": "Palworld Server",
  "slug": "palworld",
  "description": "Dedicated Palworld multiplayer server with automatic updates, backup support, and RCON management.",
  "icon": "icon.png",
  "category": "gaming",
  "version": "latest",
  "website": "https://github.com/thijsvanloef/palworld-server-docker",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-12",
    "rocky-9",
    "almalinux-9"
  ],
  "min_ram_mb": 8192,
  "min_storage_gb": 20,
  "env": [
    {
      "key": "SERVER_NAME",
      "label": "Server Name",
      "default": "My Palworld Server",
      "required": true,
      "type": "text",
      "description": "Name displayed in the server browser"
    },
    {
      "key": "SERVER_PASSWORD",
      "label": "Server Password",
      "default": "",
      "required": false,
      "type": "password",
      "description": "Password required to join the server (leave empty for public)"
    },
    {
      "key": "ADMIN_PASSWORD",
      "label": "Admin Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "RCON admin password for server management"
    },
    {
      "key": "PLAYERS",
      "label": "Max Players",
      "default": "16",
      "required": false,
      "type": "number",
      "description": "Maximum number of players"
    }
  ],
  "ports": [
    {
      "container_port": 8211,
      "default_host_port": 8211,
      "protocol": "udp",
      "label": "Game Port",
      "configurable": true
    },
    {
      "container_port": 25575,
      "default_host_port": 25575,
      "protocol": "tcp",
      "label": "RCON",
      "configurable": true
    }
  ]
}
