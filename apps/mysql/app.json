{
  "name": "MySQL",
  "slug": "mysql",
  "description": "The world's most popular open-source relational database, trusted for web applications and enterprise workloads.",
  "icon": "icon.png",
  "category": "databases",
  "version": "8.0",
  "website": "https://www.mysql.com",
  "supported_distros": [
    "ubuntu-22.04",
    "ubuntu-24.04",
    "debian-11",
    "debian-12",
    "rocky-9",
    "almalinux-9",
    "centos-stream-9"
  ],
  "min_ram_mb": 512,
  "min_storage_gb": 5,
  "env": [
    {
      "key": "MYSQL_ROOT_PASSWORD",
      "label": "Root Password",
      "default": "",
      "required": true,
      "type": "password",
      "generate": true,
      "description": "MySQL root user password"
    },
    {
      "key": "MYSQL_DATABASE",
      "label": "Default Database",
      "default": "mydb",
      "required": false,
      "type": "text",
      "description": "Name of the default database to create"
    },
    {
      "key": "MYSQL_USER",
      "label": "Database User",
      "default": "",
      "required": false,
      "type": "text",
      "description": "Additional non-root user to create"
    },
    {
      "key": "MYSQL_PASSWORD",
      "label": "User Password",
      "default": "",
      "required": false,
      "type": "password",
      "generate": true,
      "description": "Password for the additional user"
    }
  ],
  "ports": [
    {
      "container_port": 3306,
      "default_host_port": 3306,
      "protocol": "tcp",
      "label": "MySQL",
      "configurable": true
    }
  ]
}
